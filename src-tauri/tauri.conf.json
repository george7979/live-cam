{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Live Cam",
  "version": "1.0.0",
  "identifier": "com.livecam.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Live Cam",
        "width": 960,
        "height": 540,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 320,
        "minHeight": 240
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; media-src mediastream: blob:; img-src 'self' blob: data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
